<html lang="es">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>KiosKit — Sistema de ventas para PyMEs</title>
    <meta
      name="description"
      content="POS, inventario, reportes y tienda virtual para pequeñas y medianas empresas. Simple, rápido y sin letra chica."
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap"
      rel="stylesheet"
    />
  </head>

  <body class="bg-white text-slate-900 overflow-x-hidden">
    <!-- NAV -->
    <nav
      class="fixed top-0 left-0 right-0 z-50 bg-white/80 backdrop-blur-md border-b border-slate-100"
    >
      <div
        class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between"
      >
        <span class="text-xl font-bold text-indigo-600 tracking-tight"
          >KiosKit</span
        >
        <div
          class="hidden sm:flex items-center gap-8 text-sm font-medium text-slate-600"
        >
          <a
            href="#como-funciona"
            class="hover:text-slate-900 transition-colors">Cómo funciona</a
          >
          <a href="#features" class="hover:text-slate-900 transition-colors"
            >Funciones</a
          >
          <a href="#pricing" class="hover:text-slate-900 transition-colors"
            >Precio</a
          >
          <a href="#faq" class="hover:text-slate-900 transition-colors">FAQ</a>
        </div>
        <div class="flex items-center gap-3">
          <a
            href="#pricing"
            class="bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-semibold px-4 py-2 rounded-lg transition-colors"
          >
            Empezar gratis
          </a>
          <button
            id="menu-btn"
            class="sm:hidden p-2 rounded-lg hover:bg-slate-100 transition-colors"
            aria-label="Menú"
          >
            <svg
              id="icon-open"
              class="w-5 h-5"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              ><path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M4 6h16M4 12h16M4 18h16"></path></svg
            >
            <svg
              id="icon-close"
              class="w-5 h-5 hidden"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              ><path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M6 18L18 6M6 6l12 12"></path></svg
            >
          </button>
        </div>
      </div>
      <div
        id="mobile-menu"
        class="hidden sm:hidden border-t border-slate-100 bg-white px-6 pb-4"
      >
        <div
          class="flex flex-col gap-1 pt-3 text-sm font-medium text-slate-700"
        >
          <a
            href="#como-funciona"
            class="py-2 hover:text-indigo-600 transition-colors"
            data-mobile-link>Cómo funciona</a
          >
          <a
            href="#features"
            class="py-2 hover:text-indigo-600 transition-colors"
            data-mobile-link>Funciones</a
          >
          <a
            href="#pricing"
            class="py-2 hover:text-indigo-600 transition-colors"
            data-mobile-link>Precio</a
          >
          <a
            href="#faq"
            class="py-2 hover:text-indigo-600 transition-colors"
            data-mobile-link>FAQ</a
          >
        </div>
      </div>
    </nav>

    <!-- HERO -->
    <section class="relative pt-32 pb-24 px-6 text-center overflow-hidden">
      <!-- Orbes animados estilo Paddle -->
      <div class="orb orb-1"></div>
      <div class="orb orb-2"></div>
      <div class="orb orb-3"></div>

      <div class="relative z-10 max-w-4xl mx-auto">
        <div
          class="hero-fade inline-flex items-center gap-2 bg-indigo-50 border border-indigo-100 text-indigo-700 text-xs font-semibold px-3 py-1.5 rounded-full mb-6"
          style="animation-delay:0ms"
        >
          <span class="w-1.5 h-1.5 rounded-full bg-indigo-500 animate-pulse"
          ></span>
          15 días gratis · Sin tarjeta de crédito
        </div>

        <h1
          class="hero-fade text-5xl sm:text-6xl lg:text-7xl font-black tracking-tight text-slate-900 leading-[1.05] mb-6"
          style="animation-delay:80ms"
        >
          El sistema de ventas<br />
          <span class="gradient-text">para tu PyME</span>
        </h1>

        <p
          class="hero-fade text-lg sm:text-xl text-slate-500 max-w-2xl mx-auto mb-10 leading-relaxed"
          style="animation-delay:160ms"
        >
          POS, inventario, clientes y reportes en una sola plataforma. Diseñado
          para pequeños y medianos negocios que quieren vender más y perder
          menos tiempo.
        </p>

        <div
          class="hero-fade flex flex-col sm:flex-row gap-3 justify-center"
          style="animation-delay:240ms"
        >
          <a href="#pricing" class="cta-primary"> Empezar gratis → </a>
          <a href={WA_URL} target="_blank" rel="noopener" class="cta-secondary">
            <span class="w-5 h-5 text-green-500" set:html={waSvg} />
            Hablar por WhatsApp
          </a>
        </div>
      </div>

      <!-- Mock UI -->
      <div
        class="hero-fade relative z-10 mt-16 max-w-5xl mx-auto"
        style="animation-delay:320ms"
      >
        <div
          class="rounded-2xl border border-slate-200 shadow-2xl shadow-slate-200/60 overflow-hidden bg-white"
        >
          <div
