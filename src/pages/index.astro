---
import '../styles/global.css'

const WA_NUMBER = '595982373124'
const WA_URL = `https://wa.me/${WA_NUMBER}?text=Hola%2C%20me%20interesa%20saber%20m%C3%A1s%20sobre%20KiosKit`

const features = [
  {
    icon: '🖥️',
    title: 'Punto de Venta (POS)',
    desc: 'Registrá ventas al instante con búsqueda rápida de productos, descuentos por ítem y múltiples métodos de pago.',
  },
  {
    icon: '📦',
    title: 'Control de Inventario',
    desc: 'Kardex completo de movimientos, alertas de stock mínimo y ajustes de inventario con trazabilidad total.',
  },
  {
    icon: '📊',
    title: 'Reportes y Métricas',
    desc: 'Ventas diarias, productos más rentables, margen bruto y evolución de ingresos en un solo lugar.',
  },
  {
    icon: '👥',
    title: 'Gestión de Clientes',
    desc: 'Registrá tus clientes, asignalos a ventas y llevá el historial de compras de cada uno.',
  },
  {
    icon: '🛒',
    title: 'Tienda Virtual',
    desc: 'Tu propio catálogo online para recibir pedidos del storefront directamente en tu sistema.',
  },
  {
    icon: '👤',
    title: 'Múltiples Usuarios',
    desc: 'Roles de Admin, Manager y Vendedor con permisos granulares. Cada acción queda auditada.',
  },
]

const steps = [
  {
    num: '01',
    title: 'Creá tu cuenta',
    desc: 'Registrate en minutos. Sin formularios largos, sin documentación. 15 días gratis desde el primer día.',
  },
  {
    num: '02',
    title: 'Cargá tus productos',
    desc: 'Importá tu inventario o cargalo manualmente. Categorías, variantes, precios y stock en un solo lugar.',
  },
  {
    num: '03',
    title: 'Empezá a vender',
    desc: 'Tu equipo puede usar el POS desde cualquier dispositivo el mismo día. Sin instalaciones, sin configuración compleja.',
  },
]

const faqs = [
  {
    q: '¿Necesito instalar algo?',
    a: 'No. KiosKit funciona 100% en el navegador, desde cualquier dispositivo. Solo necesitás conexión a internet.',
  },
  {
    q: '¿Hay un período de prueba?',
    a: 'Sí, los primeros 15 días son completamente gratis, sin tarjeta de crédito.',
  },
  {
    q: '¿Puedo usar KiosKit en mi celular o tablet?',
    a: 'Sí, la interfaz está optimizada para mobile. El POS funciona bien en tablets y celulares sin instalar nada.',
  },
  {
    q: '¿Cuántos usuarios puedo tener?',
    a: 'Usuarios ilimitados. Podés crear roles de Admin, Manager y Vendedor con permisos diferenciados.',
  },
  {
    q: '¿Qué pasa si tengo problemas?',
    a: 'Tenés soporte directo vía WhatsApp en horario comercial. Sin chatbots ni tickets, respuesta de una persona real.',
  },
  {
    q: '¿Mis datos están seguros?',
    a: 'Tus datos se almacenan con backups automáticos. Nunca compartimos tu información con terceros.',
  },
]
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>KiosKit — Sistema de ventas para PyMEs</title>
    <meta name="description" content="POS, inventario, reportes y tienda virtual para pequeñas y medianas empresas. Simple, rápido y sin letra chica." />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
  </head>

  <body class="bg-white text-slate-900 overflow-x-hidden">

    <!-- NAV -->
    <nav class="fixed top-0 left-0 right-0 z-50 bg-white/80 backdrop-blur-md border-b border-slate-100">
      <div class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between">
        <span class="text-xl font-bold text-indigo-600 tracking-tight">KiosKit</span>

        <!-- Desktop links -->
        <div class="hidden sm:flex items-center gap-8 text-sm font-medium text-slate-600">
          <a href="#como-funciona" class="hover:text-slate-900 transition-colors">Cómo funciona</a>
          <a href="#features" class="hover:text-slate-900 transition-colors">Funciones</a>
          <a href="#pricing" class="hover:text-slate-900 transition-colors">Precio</a>
          <a href="#faq" class="hover:text-slate-900 transition-colors">FAQ</a>
        </div>

        <div class="flex items-center gap-3">
          <a
            href="#pricing"
            class="bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-semibold px-4 py-2 rounded-lg transition-colors"
          >
            Empezar gratis
          </a>
          <!-- Hamburger -->
          <button id="menu-btn" class="sm:hidden p-2 rounded-lg hover:bg-slate-100 transition-colors" aria-label="Menú">
            <svg id="icon-open" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
            </svg>
            <svg id="icon-close" class="w-5 h-5 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
            </svg>
          </button>
        </div>
      </div>

      <!-- Mobile menu -->
      <div id="mobile-menu" class="hidden sm:hidden border-t border-slate-100 bg-white px-6 pb-4">
        <div class="flex flex-col gap-1 pt-3 text-sm font-medium text-slate-700">
          <a href="#como-funciona" class="py-2 hover:text-indigo-600 transition-colors" data-mobile-link>Cómo funciona</a>
          <a href="#features" class="py-2 hover:text-indigo-600 transition-colors" data-mobile-link>Funciones</a>
          <a href="#pricing" class="py-2 hover:text-indigo-600 transition-colors" data-mobile-link>Precio</a>
          <a href="#faq" class="py-2 hover:text-indigo-600 transition-colors" data-mobile-link>FAQ</a>
        </div>
      </div>
    </nav>

    <!-- HERO -->
    <section class="pt-32 pb-24 px-6 text-center bg-gradient-to-b from-indigo-50/70 via-white to-white">
      <div class="max-w-4xl mx-auto">
        <div class="animate-fade-up inline-flex items-center gap-2 bg-indigo-50 border border-indigo-100 text-indigo-700 text-xs font-semibold px-3 py-1.5 rounded-full mb-6">
          <span class="w-1.5 h-1.5 rounded-full bg-indigo-500 animate-pulse"></span>
          15 días gratis · Sin tarjeta de crédito
        </div>
        <h1 class="animate-fade-up [animation-delay:80ms] text-5xl sm:text-6xl lg:text-7xl font-black tracking-tight text-slate-900 leading-[1.05] mb-6">
          El sistema de ventas<br />
          <span class="text-indigo-600">para tu PyME</span>
        </h1>
        <p class="animate-fade-up [animation-delay:160ms] text-lg sm:text-xl text-slate-500 max-w-2xl mx-auto mb-10 leading-relaxed">
          POS, inventario, clientes y reportes en una sola plataforma. Diseñado para pequeños y medianos negocios que quieren vender más y perder menos tiempo.
        </p>
        <div class="animate-fade-up [animation-delay:240ms] flex flex-col sm:flex-row gap-3 justify-center">
          <a
            href="#pricing"
            class="bg-indigo-600 hover:bg-indigo-700 text-white font-semibold px-8 py-4 rounded-xl text-base transition-all shadow-lg shadow-indigo-200 hover:shadow-indigo-300 hover:-translate-y-0.5"
          >
            Empezar gratis →
          </a>
          <a
            href={WA_URL}
            target="_blank"
            rel="noopener"
            class="bg-white hover:bg-slate-50 text-slate-700 font-semibold px-8 py-4 rounded-xl text-base border border-slate-200 transition-colors flex items-center justify-center gap-2"
          >
            <svg class="w-5 h-5 text-green-500" fill="currentColor" viewBox="0 0 24 24">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            Hablar por WhatsApp
          </a>
        </div>
      </div>

      <!-- Mock UI -->
      <div class="animate-fade-up [animation-delay:320ms] mt-16 max-w-5xl mx-auto">
        <div class="rounded-2xl border border-slate-200 shadow-2xl shadow-slate-200/80 overflow-hidden bg-white">
          <div class="flex items-center gap-2 px-4 py-3 bg-slate-50 border-b border-slate-200">
            <div class="flex gap-1.5">
              <span class="w-3 h-3 rounded-full bg-red-400"></span>
              <span class="w-3 h-3 rounded-full bg-amber-400"></span>
              <span class="w-3 h-3 rounded-full bg-green-400"></span>
            </div>
            <div class="flex-1 mx-4 bg-white border border-slate-200 rounded-md px-3 py-1 text-xs text-slate-400 text-center">
              app.kioskit.com/pos
            </div>
          </div>
          <div class="grid grid-cols-5 h-72 sm:h-96">
            <div class="col-span-3 p-4 border-r border-slate-100">
              <div class="flex gap-2 mb-4">
                <div class="flex-1 bg-slate-100 rounded-lg h-8 flex items-center px-3">
                  <div class="w-3 h-3 rounded-full bg-slate-300 mr-2"></div>
                  <div class="h-2 bg-slate-200 rounded w-1/3"></div>
                </div>
                <div class="w-16 bg-indigo-100 rounded-lg h-8 flex items-center justify-center">
                  <div class="h-2 bg-indigo-300 rounded w-8"></div>
                </div>
              </div>
              <div class="grid grid-cols-3 gap-2">
                {Array.from({length: 9}).map((_, i) => (
                  <div class={`rounded-xl p-3 cursor-pointer transition-all ${i === 2 ? 'bg-indigo-50 border-2 border-indigo-300 scale-105' : 'bg-slate-50 border border-slate-100 hover:border-slate-200'}`}>
                    <div class={`w-8 h-8 rounded-lg mb-2 ${i === 2 ? 'bg-indigo-200' : 'bg-slate-200'}`}></div>
                    <div class="h-2 bg-slate-200 rounded w-3/4 mb-1"></div>
                    <div class={`h-2 rounded w-1/2 ${i === 2 ? 'bg-indigo-200' : 'bg-slate-200'}`}></div>
                  </div>
                ))}
              </div>
            </div>
            <div class="col-span-2 p-4 flex flex-col">
              <p class="text-xs font-semibold text-slate-400 mb-3">Venta actual · 3 ítems</p>
              <div class="space-y-2 flex-1">
                {['Creatina Landerfit BR', 'Whey ProFit 1kg', 'Omega 3 UniErvas'].map((name) => (
                  <div class="flex items-center gap-2 bg-slate-50 rounded-lg p-2.5">
                    <div class="w-6 h-6 rounded bg-indigo-100 shrink-0"></div>
                    <div class="flex-1 min-w-0">
                      <div class="h-2 bg-slate-300 rounded w-4/5 mb-1"></div>
                      <div class="h-1.5 bg-slate-200 rounded w-1/2"></div>
                    </div>
                    <div class="h-2 bg-indigo-300 rounded w-8 shrink-0"></div>
                  </div>
                ))}
              </div>
              <div class="mt-4 pt-3 border-t border-slate-100 space-y-2">
                <div class="flex justify-between text-xs">
                  <span class="text-slate-400">Subtotal</span>
                  <span class="text-slate-500">Gs. 577.000</span>
                </div>
                <div class="flex justify-between text-xs">
                  <span class="text-slate-400">Descuento</span>
                  <span class="text-green-500">-Gs. 20.000</span>
                </div>
                <div class="flex justify-between text-xs font-bold">
                  <span class="text-slate-700">Total</span>
                  <span class="text-slate-900">Gs. 557.000</span>
                </div>
                <div class="w-full bg-indigo-600 text-white text-xs font-semibold py-2.5 rounded-lg text-center mt-1">
                  Finalizar Venta
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- PARA QUIÉN ES -->
    <section class="py-16 border-y border-slate-100 bg-slate-50/50">
      <div class="max-w-6xl mx-auto px-6">
        <p class="text-center text-sm text-slate-400 font-medium mb-10" data-animate>KiosKit está hecho para negocios como estos</p>
        <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-4" data-animate>
          {[
            { icon: '💊', label: 'Farmacias' },
            { icon: '👗', label: 'Ropa y moda' },
            { icon: '🍔', label: 'Restaurantes' },
            { icon: '💪', label: 'Suplementos' },
            { icon: '🛒', label: 'Minimarkets' },
            { icon: '✂️', label: 'Peluquerías' },
          ].map((item) => (
            <div class="flex flex-col items-center gap-2 p-4 bg-white rounded-xl border border-slate-100 hover:border-indigo-100 hover:shadow-sm transition-all">
              <span class="text-2xl">{item.icon}</span>
              <span class="text-xs font-medium text-slate-600">{item.label}</span>
            </div>
          ))}
        </div>
        <p class="text-center text-xs text-slate-400 mt-6" data-animate>Y cualquier negocio que quiera vender más y ordenarse mejor.</p>
      </div>
    </section>

    <!-- CÓMO FUNCIONA -->
    <section id="como-funciona" class="py-24 px-6">
      <div class="max-w-6xl mx-auto">
        <div class="text-center mb-16" data-animate>
          <p class="text-sm font-semibold text-indigo-600 mb-3 uppercase tracking-wider">Simple de arrancar</p>
          <h2 class="text-4xl sm:text-5xl font-black text-slate-900 tracking-tight mb-4">
            Listo para vender<br />en minutos
          </h2>
          <p class="text-slate-500 text-lg max-w-xl mx-auto">Sin técnicos, sin instalaciones, sin semanas de configuración.</p>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-3 gap-8 relative">
          <!-- Línea conectora (desktop) -->
          <div class="hidden sm:block absolute top-8 left-1/6 right-1/6 h-px bg-gradient-to-r from-transparent via-indigo-200 to-transparent"></div>

          {steps.map((step, i) => (
            <div class="text-center relative" data-animate style={`animation-delay: ${i * 100}ms`}>
              <div class="w-16 h-16 rounded-2xl bg-indigo-600 text-white font-black text-xl flex items-center justify-center mx-auto mb-6 shadow-lg shadow-indigo-200">
                {step.num}
              </div>
              <h3 class="font-bold text-slate-900 text-xl mb-3">{step.title}</h3>
              <p class="text-slate-500 text-sm leading-relaxed max-w-xs mx-auto">{step.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- FEATURES -->
    <section id="features" class="py-24 px-6 bg-slate-50">
      <div class="max-w-6xl mx-auto">
        <div class="text-center mb-16" data-animate>
          <p class="text-sm font-semibold text-indigo-600 mb-3 uppercase tracking-wider">Todo en uno</p>
          <h2 class="text-4xl sm:text-5xl font-black text-slate-900 tracking-tight mb-4">
            Herramientas pensadas<br />para PyMEs
          </h2>
          <p class="text-slate-500 text-lg max-w-xl mx-auto">
            Sin apps separadas, sin planillas de Excel, sin dolores de cabeza.
          </p>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {features.map((f, i) => (
            <div
              class="group p-6 rounded-2xl border border-slate-100 bg-white hover:border-indigo-100 hover:shadow-xl hover:shadow-indigo-50 transition-all duration-300 hover:-translate-y-1"
              data-animate
              style={`animation-delay: ${i * 80}ms`}
            >
              <div class="w-12 h-12 rounded-xl bg-indigo-50 flex items-center justify-center text-2xl mb-4 group-hover:bg-indigo-100 transition-colors group-hover:scale-110 transition-transform duration-300">
                {f.icon}
              </div>
              <h3 class="font-bold text-slate-900 text-lg mb-2">{f.title}</h3>
              <p class="text-slate-500 text-sm leading-relaxed">{f.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- MIGRACIÓN -->
    <section class="py-24 px-6 bg-slate-50">
      <div class="max-w-5xl mx-auto">
        <div class="rounded-3xl bg-white border border-slate-100 shadow-xl p-10 sm:p-14 flex flex-col sm:flex-row items-center gap-10" data-animate>
          <div class="text-5xl sm:text-6xl shrink-0">📦</div>
          <div class="text-center sm:text-left">
            <div class="inline-flex items-center gap-2 bg-amber-50 border border-amber-100 text-amber-700 text-xs font-semibold px-3 py-1.5 rounded-full mb-4">
              ¿Ya usás otro sistema de ventas?
            </div>
            <h2 class="text-3xl sm:text-4xl font-black text-slate-900 tracking-tight mb-4">
              Migramos todo por vos
            </h2>
            <p class="text-slate-500 leading-relaxed mb-6 max-w-xl">
              Cambiar de sistema puede parecer difícil, pero no tiene que serlo. Si tenés tu inventario en Excel, en otra app o en cualquier formato, <strong class="text-slate-700">te ayudamos a importar todo a KiosKit</strong> sin perder nada: productos, variantes, stock y precios.
            </p>
            <a
              href={WA_URL}
              target="_blank"
              rel="noopener"
              class="inline-flex items-center gap-2 bg-indigo-600 hover:bg-indigo-700 text-white font-semibold px-6 py-3 rounded-xl transition-all hover:-translate-y-0.5 shadow-lg shadow-indigo-100"
            >
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
              Consultanos por WhatsApp
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- ROADMAP -->
    <section class="py-24 px-6">
      <div class="max-w-6xl mx-auto">
        <div class="text-center mb-16" data-animate>
          <p class="text-sm font-semibold text-indigo-600 mb-3 uppercase tracking-wider">Roadmap</p>
          <h2 class="text-4xl sm:text-5xl font-black text-slate-900 tracking-tight mb-4">
            Lo que se viene
          </h2>
          <p class="text-slate-500 text-lg max-w-xl mx-auto">
            Estamos construyendo KiosKit todos los días. Esto es lo que viene próximamente.
          </p>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
          {[
            { icon: '📱', title: 'App nativa Android & iOS', desc: 'Velocidad nativa, notificaciones push y funcionalidades exclusivas para móvil.', tag: 'En desarrollo' },
            { icon: '🧾', title: 'Facturación electrónica', desc: 'Integración con SIFEN para emitir facturas timbradas directamente desde el sistema.', tag: 'Próximamente' },
            { icon: '🏪', title: 'Multi-sucursal', desc: 'Manejá varios locales desde una sola cuenta con inventarios independientes.', tag: 'Próximamente' },
            { icon: '💳', title: 'Pagos digitales', desc: 'Integración con Bancard y PagoExpress para cobrar con QR y tarjetas sin fricción.', tag: 'Próximamente' },
            { icon: '⭐', title: 'Fidelización de clientes', desc: 'Sistema de puntos y descuentos automáticos para recompensar a tus clientes frecuentes.', tag: 'Próximamente' },
            { icon: '🏦', title: 'Módulo de caja', desc: 'Apertura y cierre de caja, arqueo y control de turnos para tu equipo.', tag: 'Próximamente' },
          ].map((item, i) => (
            <div
              class="p-6 rounded-2xl border border-slate-100 bg-white hover:border-indigo-100 hover:shadow-lg hover:shadow-indigo-50 transition-all duration-300 hover:-translate-y-1 group"
              data-animate
              style={`animation-delay: ${i * 80}ms`}
            >
